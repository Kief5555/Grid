# Required Environment Variables
JWT=your-super-secret-jwt-key-here-make-it-long-and-random
RKEY=your-registration-key-for-new-users

# Optional Environment Variables
PORT=3020

# Storage Configuration
# DATA_DIR=./data
# FILES_DIR=./files
# TEMP_DIR=./temp

# Upload Configuration
# MAX_FILE_SIZE=1073741824
# CHUNK_SIZE=5242880
# CONCURRENT_CHUNKS=3
# FILTER_MIME=false

# Rate Limiting Configuration
# RATE_LIMIT_WINDOW=900000
# RATE_LIMIT_MAX=100
# UPLOAD_RATE_LIMIT_WINDOW=3600000
# UPLOAD_RATE_LIMIT_MAX=30
# CHUNK_RATE_LIMIT_WINDOW=3600000
# CHUNK_RATE_LIMIT_MAX=1000
# AUTH_RATE_LIMIT_WINDOW=900000
# AUTH_RATE_LIMIT_MAX=10

# Security Configuration
# SESSION_SECRET=your-session-secret
# COOKIE_SECURE=true
# COOKIE_HTTP_ONLY=true
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_ALLOW_CREDENTIALS=false
# SHARE_VIEW_URL=https://printedwaste.com/grid/view/

# Logging Configuration
# LOG_LEVEL=info
# LOG_FILE=./logs/app.log

# Cloudflare Configuration
# TRUST_PROXY=true
# CF_IP_HEADER=cf-connecting-ip
